// See this for installing the nvidia container toolkit (for systems that have nvidia gpus)
// https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/latest/install-guide.html

{
    "name": "C++ Dev",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "runArgs": [
        "--gpus", "all",

        // Exposes integrated GPU (Intel)
        "--device=/dev/dri",

        //"--device=/dev/dri/card1",
        //"--device=/dev/dri/renderD128",
        //"--device=/dev/dri/card2",
        //"--device=/dev/dri/renderD129",
        // Required to enable vscode user to read the above device nodes

        "--group-add=990"
    ],

    //"features": {
    //    "ghcr.io/devcontainers/features/nvidia-cuda:2": {}
    //},
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "matepek.vscode-catch2-test-adapter",
                "mhutchie.git-graph"
            ]
        }
    },
    "remoteEnv": {
        "PATH": "${containerEnv:PATH}:/usr/local/cuda/bin"
    },
    
    "remoteUser": "vscode"
}   